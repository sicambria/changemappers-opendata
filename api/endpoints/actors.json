          "type": "string",
          "required": false
        },
        "description": {
          "type": "string",
          "required": false
        },
        "location": {
          "type": "object",
          "required": false
        },
        "tags": {
          "type": "array",
          "items": "string",
          "required": false
        },
        "metadata": {
          "type": "object",
          "required": false
        }
      }
    },
    "DELETE": {
      "query": {
        "id": {
          "type": "string",
          "required": true,
          "description": "Actor ID to delete"
        }

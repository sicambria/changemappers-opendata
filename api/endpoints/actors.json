        "description": {
          "type": "string",
          "required": false,
          "maxLength": 5000
        },
        "location": {
          "type": "object",
          "required": false,
          "properties": {
            "city": { "type": "string" },
            "country": { "type": "string" },
            "region": { "type": "string" },
            "coordinates": {
              "type": "object",
              "properties": {
                "lat": { "type": "number" },
                "lng": { "type": "number" }
              }
            }
          }
        },
        "tags": {
          "type": "array",
          "items": "string",
          "required": false
        },
        "metadata": {
          "type": "object",
          "required": false,
          "description": "Additional metadata fields"

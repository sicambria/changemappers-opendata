{
  "endpoint": "/search",
  "path": "/v1/search",
  "httpMethods": ["GET"],
  "parameters": {
    "GET": {
      "query": {
        "q": {
          "type": "string",
          "required": true,
          "minLength": 1,
          "maxLength": 500,
          "description": "Search query string"
        },
        "types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["actors", "organizations", "initiatives", "causes", "patterns", "stories", "all"]
          },
          "required": false,
          "default": ["all"],
          "description": "Entity types to search"
        },
        "filters": {
          "type": "object",
          "required": false,
          "properties": {
            "location": {
              "type": "string",
              "description": "Filter by location"
            },
            "category": {
              "type": "string",
              "description": "Filter by category (context-dependent)"
            },
            "tags": {
              "type": "array",
              "items": "string",
              "description": "Filter by tags"
            },
            "date_from": {
              "type": "string",
              "format": "date",
              "description": "Filter from date"
            },
            "date_to": {
              "type": "string",
              "format": "date",
              "description": "Filter to date"
            }
          }
        },
        "facets": {
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "Include facet counts in response"
        },
        "highlight": {
          "type": "boolean",
          "required": false,
          "default": true,
          "description": "Highlight matching terms in results"
        },
        "limit": {
          "type": "integer",
          "required": false,
          "default": 20,
          "minimum": 1,
          "maximum": 100,
          "description": "Number of results per page"
        },
        "offset": {
          "type": "integer",
          "required": false,
          "default": 0,
          "minimum": 0,
          "description": "Pagination offset"
        },
        "sort": {
          "type": "string",
          "required": false,
          "enum": ["relevance", "name", "created_at", "updated_at"],
          "default": "relevance",
          "description": "Sort field"
        },
        "order": {
          "type": "string",
          "required": false,
          "enum": ["asc", "desc"],
          "default": "desc",
          "description": "Sort order"
        }
      }
    }
  },
  "responseSchema": {
    "success": {
      "type": "object",
      "properties": {
        "query": { "type": "string" },
        "results": {
          "type": "object",
          "properties": {
            "actors": {
              "type": "object",
              "properties": {
                "count": { "type": "integer" },
                "items": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/SearchResult"
                  }
                }
              }
            },
            "organizations": {
              "type": "object",
              "properties": {
                "count": { "type": "integer" },
                "items": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/SearchResult"
                  }
                }
              }
            },
            "initiatives": {
              "type": "object",
              "properties": {
                "count": { "type": "integer" },
                "items": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/SearchResult"
                  }
                }
              }
            },
            "causes": {
              "type": "object",
              "properties": {
                "count": { "type": "integer" },
                "items": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/SearchResult"
                  }
                }
              }
            },
            "patterns": {
              "type": "object",
              "properties": {
                "count": { "type": "integer" },
                "items": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/SearchResult"
                  }
                }
              }
            },
            "stories": {
              "type": "object",
              "properties": {
                "count": { "type": "integer" },
                "items": {
                  "type": "array",
                  "items": {
                    "$ref": "#/definitions/SearchResult"
                  }
                }
              }
            }
          }
        },
        "facets": {
          "type": "object",
          "properties": {
            "types": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "count": { "type": "integer" }
                }
              }
            },
            "locations": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "count": { "type": "integer" }
                }
              }
            },
            "categories": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "count": { "type": "integer" }
                }
              }
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "count": { "type": "integer" }
                }
              }
            }
          }
        },
        "total_results": { "type": "integer" },
        "pagination": {
          "$ref": "#/definitions/Pagination"
        }
      },
      "definitions": {
        "SearchResult": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "type": { "type": "string" },
            "name": { "type": "string" },
            "description": { "type": "string" },
            "highlight": {
              "type": "object",
              "properties": {
                "name": { "type": "array", "items": { "type": "string" } },
                "description": { "type": "array", "items": { "type": "string" } },
                "content": { "type": "array", "items": { "type": "string" } }
              }
            },
            "score": { "type": "number", "description": "Relevance score" },
            "url": { "type": "string", "description": "API URL to fetch full entity" },
            "snippet": { "type": "string", "description": "Brief snippet with context" }
          }
        },
        "Pagination": {
          "type": "object",
          "properties": {
            "total": { "type": "integer" },
            "limit": { "type": "integer" },
            "offset": { "type": "integer" },
            "has_more": { "type": "boolean" }
          }
        }
      }
    }
  },
  "examples": {
    "request": {
      "GET": {
        "basic_search": "?q=climate",
        "search_with_types": "?q=climate&types=organizations,initiatives",
        "search_with_filters": "?q=climate&filters[location]=Germany&filters[tags]=activism",
        "search_sorted_by_date": "?q=climate&sort=created_at&order=desc",
        "search_without_facets": "?q=climate&facets=false",
        "search_with_limit": "?q=climate&limit=50"
      }
    },

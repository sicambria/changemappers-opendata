{
  "endpoint": "/organizations",
  "path": "/v1/organizations",
  "httpMethods": ["GET", "POST", "PUT", "DELETE"],
  "parameters": {
    "GET": {
      "query": {
        "id": {
          "type": "string",
          "required": false,
          "description": "Unique organization identifier"
        },
        "name": {
          "type": "string",
          "required": false,
          "description": "Search by organization name (partial match)"
        },
        "type": {
          "type": "string",
          "required": false,
          "enum": ["ngo", "nonprofit", "social_enterprise", "cooperative", "foundation", "community_group", "network"],
          "description": "Filter by organization type"
        },
        "sector": {
          "type": "string",
          "required": false,
          "enum": ["environment", "social_justice", "education", "health", "economic_development", "arts_culture", "human_rights", "community_development"],
          "description": "Filter by sector"
        },
        "location": {
          "type": "string",
          "required": false,
          "description": "Filter by location (city, country, or region)"
        },
        "size": {
          "type": "string",
          "required": false,
          "enum": ["small", "medium", "large"],
          "description": "Filter by organization size"
        },
        "founded_year": {
          "type": "integer",
          "required": false,
          "description": "Filter by founding year"
        },
        "tags": {
          "type": "array",
          "items": "string",
          "required": false,
          "description": "Filter by tags"
        },
        "limit": {
          "type": "integer",
          "required": false,
          "default": 20,
          "minimum": 1,
          "maximum": 100
        },
        "offset": {
          "type": "integer",
          "required": false,
          "default": 0,
          "minimum": 0
        },
        "sort": {
          "type": "string",
          "required": false,
          "enum": ["name", "founded_year", "size", "created_at", "updated_at"],
          "default": "name"
        },
        "order": {
          "type": "string",
          "required": false,
          "enum": ["asc", "desc"],
          "default": "asc"
        }
      }
    },
    "POST": {
      "body": {
        "name": {
          "type": "string",
          "required": true,
          "minLength": 1,
          "maxLength": 255
        },
        "type": {
          "type": "string",
          "required": true,
          "enum": ["ngo", "nonprofit", "social_enterprise", "cooperative", "foundation", "community_group", "network"]
        },
        "description": {
          "type": "string",
          "required": false,
          "maxLength": 5000
        },
        "sector": {
          "type": "string",
          "required": false,
          "enum": ["environment", "social_justice", "education", "health", "economic_development", "arts_culture", "human_rights", "community_development"]
        },
        "location": {
          "type": "object",
          "required": false,
          "properties": {
            "city": { "type": "string" },
            "country": { "type": "string" },
            "region": { "type": "string" },
            "coordinates": {
              "type": "object",
              "properties": {
                "lat": { "type": "number" },
                "lng": { "type": "number" }
              }
            }
          }
        },
        "size": {
          "type": "string",
          "required": false,
          "enum": ["small", "medium", "large"]
        },
        "founded_year": {
          "type": "integer",
          "required": false,
          "minimum": 1800,
          "maximum": 2100
        },
        "website": {
          "type": "string",
          "format": "uri",
          "required": false
        },
        "contact": {
          "type": "object",
          "required": false,
          "properties": {
            "email": { "type": "string", "format": "email" },
            "phone": { "type": "string" },
            "social_media": {
              "type": "object",
              "properties": {
                "twitter": { "type": "string" },
                "facebook": { "type": "string" },
                "linkedin": { "type": "string" },
                "instagram": { "type": "string" }
              }
            }
          }
        },
        "tags": {
          "type": "array",
          "items": "string",
          "required": false
        },
        "metadata": {
          "type": "object",
          "required": false
        }
      }
    },
    "PUT": {
      "query": {
        "id": {
          "type": "string",
          "required": true
        }
      },
      "body": {
        "name": { "type": "string", "required": false },
        "description": { "type": "string", "required": false },
        "sector": { "type": "string", "required": false },
        "location": { "type": "object", "required": false },
        "size": { "type": "string", "required": false },
        "website": { "type": "string", "format": "uri", "required": false },
        "contact": { "type": "object", "required": false },
        "tags": { "type": "array", "items": "string", "required": false },
        "metadata": { "type": "object", "required": false }
      }
    },
    "DELETE": {
      "query": {
        "id": {
          "type": "string",
          "required": true
        }
      }
    }
  },
  "responseSchema": {
    "GET": {
      "success": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/Organization"
            }
          },
          "pagination": {
            "$ref": "#/definitions/Pagination"
          }
        }
      },
      "definitions": {
        "Organization": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "type": { "type": "string" },
            "description": { "type": "string" },
            "sector": { "type": "string" },
            "location": {
              "type": "object",
              "properties": {
                "city": { "type": "string" },
                "country": { "type": "string" },
                "region": { "type": "string" },
                "coordinates": {
                  "type": "object",
                  "properties": {
                    "lat": { "type": "number" },
                    "lng": { "type": "number" }
                  }
                }
              }
            },
            "size": { "type": "string" },
            "founded_year": { "type": "integer" },
            "website": { "type": "string" },
            "contact": {
              "type": "object",
              "properties": {
                "email": { "type": "string" },
                "phone": { "type": "string" },
                "social_media": { "type": "object" }
              }
            },
            "tags": { "type": "array", "items": { "type": "string" } },
            "metadata": { "type": "object" },
            "relationships": {
              "type": "object",
              "properties": {
                "members": { "type": "integer" },
                "initiatives": { "type": "integer" },
                "partners": { "type": "integer" },
                "causes": { "type": "integer" }
              }
            },
            "created_at": { "type": "string", "format": "date-time" },
            "updated_at": { "type": "string", "format": "date-time" }
          }
        },
        "Pagination": {
          "type": "object",
          "properties": {
            "total": { "type": "integer" },
            "limit": { "type": "integer" },
            "offset": { "type": "integer" },
            "has_more": { "type": "boolean" }
          }
        }
      }
    },
    "POST": {
      "success": {
        "$ref": "#/definitions/Organization"
      }
    },
    "PUT": {
      "success": {
        "$ref": "#/definitions/Organization"
      }
    },
    "DELETE": {
      "success": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "id": { "type": "string" }
        }
      }
    }
  },
  "examples": {
    "request": {
      "GET": {
        "list_organizations": "?limit=20&sort=name&order=asc",
        "filter_by_sector": "?sector=environment&limit=20",
        "filter_by_type": "?type=ngo&sector=social_justice",
        "search_by_name": "?name=green",
        "filter_by_location": "?location=Germany",
        "filter_by_size": "?size=large",
        "filter_by_tags": "?tags=climate,advocacy"
      },
      "POST": {
        "create_organization": {
          "name": "Green Future Initiative",
          "type": "ngo",
          "description": "Environmental advocacy organization focused on sustainable development",
          "sector": "environment",
          "location": {
            "city": "Berlin",
            "country": "Germany",
            "region": "Europe"
          },
          "size": "medium",
          "founded_year": 2015,
          "website": "https://greenfuture.org",

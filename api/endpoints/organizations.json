            "email": "info@greenfuture.org",
            "social_media": {
              "twitter": "@greenfuture",
              "linkedin": "green-future-initiative"
            }
          },
          "tags": ["environment", "sustainability", "advocacy", "climate"]
        }
      },
      "PUT": {
        "update_organization": {
          "id": "org_abc123",
          "description": "Updated description for the organization",
          "tags": ["environment", "sustainability", "advocacy", "climate", "policy"]
        }
      }
    },

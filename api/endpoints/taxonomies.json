{
  "endpoint": "/taxonomies",
  "path": "/v1/taxonomies",
  "httpMethods": ["GET"],
  "parameters": {
    "GET": {
      "query": {
        "name": {
          "type": "string",
          "required": false,
          "enum": ["sectors", "organization_types", "initiative_types", "cause_categories", "pattern_categories", "relationship_types", "sdg", "urgency_levels", "scopes", "all"],
          "description": "Name of the taxonomy to retrieve",
          "default": "all"
        },
        "include_counts": {
          "type": "boolean",
          "required": false,
          "default": false,
          "description": "Include usage counts for each taxonomy term"
        },
        "format": {
          "type": "string",
          "required": false,
          "enum": ["flat", "tree", "graph"],
          "default": "flat",
          "description": "Output format for taxonomy"
        },
        "lang": {
          "type": "string",
          "required": false,
          "default": "en",
          "description": "Language code for labels (if translations available)"
        }
      }
    }
  },
  "responseSchema": {
    "success": {
      "type": "object",
      "properties": {
        "taxonomies": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/Taxonomy"
          }
        }
      },
      "definitions": {
        "Taxonomy": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "description": { "type": "string" },
            "terms": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/TaxonomyTerm"
              }
            }
          }
        },
        "TaxonomyTerm": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "label": { "type": "string" },
            "description": { "type": "string" },
            "parent_id": { "type": "string" },
            "children": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/TaxonomyTerm"
              }
            },
            "count": {
              "type": "integer",
              "description": "Usage count (only if include_counts=true)"
            },
            "metadata": { "type": "object" }
          }
        }
      }
    }
  },
  "examples": {
    "request": {
      "GET": {
        "all_taxonomies": "?include_counts=true",
        "specific_taxonomy": "?name=sectors",
        "tree_format": "?name=cause_categories&format=tree",
        "graph_format": "?name=relationship_types&format=graph"
      }
    },

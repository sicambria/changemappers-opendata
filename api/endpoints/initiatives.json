  "parameters": {
    "GET": {
      "query": {
        "id": {
          "type": "string",
          "required": false,
          "description": "Unique initiative identifier"
        },
        "name": {
          "type": "string",
          "required": false,
          "description": "Search by initiative name (partial match)"
        },
        "type": {
          "type": "string",
          "required": false,
          "enum": ["project", "campaign", "program", "event", "research", "pilot"],
          "description": "Filter by initiative type"
        },
        "status": {
          "type": "string",
          "required": false,
          "enum": ["planning", "active", "completed", "on_hold", "cancelled"],
          "description": "Filter by status"
        },
        "organization_id": {
          "type": "string",
          "required": false,
          "description": "Filter by organization ID"
        },
        "cause_id": {
          "type": "string",
          "required": false,
          "description": "Filter by cause ID"
        },
        "location": {
          "type": "string",
          "required": false,
          "description": "Filter by location"
        },
        "start_date": {
          "type": "string",
          "format": "date",
          "required": false,
          "description": "Filter initiatives starting after this date"
        },
        "end_date": {
          "type": "string",
          "format": "date",
          "required": false,
          "description": "Filter initiatives ending before this date"
        },
        "tags": {
          "type": "array",
          "items": "string",
          "required": false
        },
        "limit": {
          "type": "integer",
          "required": false,
          "default": 20,
          "minimum": 1,
          "maximum": 100
        },
        "offset": {
          "type": "integer",
          "required": false,
          "default": 0,
          "minimum": 0
        },
        "sort": {
          "type": "string",
          "required": false,
          "enum": ["name", "start_date", "end_date", "created_at", "updated_at"],
          "default": "name"
        },
        "order": {
          "type": "string",
          "required": false,
          "enum": ["asc", "desc"],
          "default": "asc"
        }
      }
    },
    "POST": {
      "body": {
        "name": {
          "type": "string",
          "required": true,
          "minLength": 1,
          "maxLength": 255
        },
        "type": {
          "type": "string",
          "required": true,
          "enum": ["project", "campaign", "program", "event", "research", "pilot"]
        },
        "description": {
          "type": "string",
          "required": false,
          "maxLength": 10000
        },
        "status": {
          "type": "string",
          "required": false,
          "enum": ["planning", "active", "completed", "on_hold", "cancelled"],
          "default": "planning"
        },
        "organization_id": {
          "type": "string",
          "required": false,
          "description": "ID of the organization leading this initiative"
        },
        "cause_id": {
          "type": "string",
          "required": false,
          "description": "ID of the primary cause this initiative addresses"
        },
        "location": {
          "type": "object",
          "required": false,
          "properties": {
            "city": { "type": "string" },
            "country": { "type": "string" },
            "region": { "type": "string" },
            "coordinates": {
              "type": "object",
              "properties": {
                "lat": { "type": "number" },
                "lng": { "type": "number" }
              }
            }
          }
        },
        "start_date": {
          "type": "string",
          "format": "date",
          "required": false
        },
        "end_date": {
          "type": "string",
          "format": "date",
          "required": false
        },
        "budget": {
          "type": "object",
          "required": false,
          "properties": {
            "amount": { "type": "number" },
            "currency": { "type": "string", "default": "EUR" }
          }
        },
        "target_audience": {
          "type": "string",
          "required": false
        },
        "expected_outcomes": {
          "type": "array",
          "items": "string",
          "required": false
        },
        "tags": {
          "type": "array",
          "items": "string",
          "required": false
        },
        "metadata": {
          "type": "object",
          "required": false
        }
      }
    },
    "PUT": {
      "query": {
        "id": {
          "type": "string",
          "required": true
        }
      },

        "description": { "type": "string", "required": false },
        "status": { "type": "string", "required": false },
        "organization_id": { "type": "string", "required": false },
        "cause_id": { "type": "string", "required": false },
        "location": { "type": "object", "required": false },
        "start_date": { "type": "string", "format": "date", "required": false },
        "end_date": { "type": "string", "format": "date", "required": false },
        "budget": { "type": "object", "required": false },
        "target_audience": { "type": "string", "required": false },
        "expected_outcomes": { "type": "array", "items": "string", "required": false },
        "tags": { "type": "array", "items": "string", "required": false },
        "metadata": { "type": "object", "required": false }
      }
    },
    "DELETE": {

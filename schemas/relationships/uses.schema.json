{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://changemappers.org/schemas/relationships/uses.schema.json",
  "title": "Uses",
  "description": "An Entity employs, utilizes, or leverages a Tool, Resource, Technology, or Platform. This captures the means and methods employed.",
  "type": "object",
  "required": [
    "id",
    "source_id",
    "target_id",
    "relationship_type"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the relationship"
    },
    "source_id": {
      "type": "string",
      "format": "uuid",
      "description": "ID of the source entity"
    },
    "target_id": {
      "type": "string",
      "format": "uuid",
      "description": "ID of the target entity"
    },
    "relationship_type": {
      "type": "string",
      "const": "uses",
      "description": "Type of relationship"
    },
    "source_type": {
      "type": "string",
      "description": "Type of the source entity",
      "enum": [
        "Initiative",
        "Project",
        "Organization",
        "Person",
        "Activity"
      ]
    },
    "target_type": {
      "type": "string",
      "description": "Type of the target entity",
      "enum": [
        "Tool",
        "Resource",
        "Technology",
        "Platform",
        "Infrastructure",
        "Method"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score for this relationship (0-1)"
    },
    "source_reference": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "official",
            "news",
            "research",
            "social",
            "government",
            "ngo",
            "corporate",
            "other"
          ]
        },
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "type",
        "name"
      ],
      "description": "Source of the relationship information"
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "When the relationship became valid"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "When the relationship ceased to be valid"
    },
    "is_current": {
      "type": "boolean",
      "description": "Whether the relationship is currently active"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this record was created"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this record was last updated"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes about the relationship"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tags for categorizing the relationship"
    },
    "usage_frequency": {
      "type": "string",
      "description": "How often the tool is used (continuous, daily, weekly, occasional)"
    },
    "adoption_date": {
      "type": "string",
      "format": "date",
      "description": "When the tool was adopted"
    },
    "effectiveness": {
      "type": "number",
      "description": "How effective the tool is (0.0-1.0)"
    },
    "cost": {
      "type": "string",
      "description": "Cost of using the tool"
    },
    "training_required": {
      "type": "boolean",
      "description": "Whether training is needed to use the tool"
    }
  },
  "x-inverse": "used_by",
  "x-cardinality": "many-to-many"
}

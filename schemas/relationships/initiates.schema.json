{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://changemappers.org/schemas/relationships/initiates.schema.json",
  "title": "Initiates",
  "description": "An Actor (person, organization, or group) starts, launches, or begins an Initiative, Project, or Campaign. This relationship captures the origin point and ownership of change-making activities.",
  "type": "object",
  "required": [
    "id",
    "source_id",
    "target_id",
    "relationship_type"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the relationship"
    },
    "source_id": {
      "type": "string",
      "format": "uuid",
      "description": "ID of the source entity"
    },
    "target_id": {
      "type": "string",
      "format": "uuid",
      "description": "ID of the target entity"
    },
    "relationship_type": {
      "type": "string",
      "const": "initiates",
      "description": "Type of relationship"
    },
    "source_type": {
      "type": "string",
      "description": "Type of the source entity",
      "enum": [
        "Actor",
        "Organization",
        "Person",
        "Group"
      ]
    },
    "target_type": {
      "type": "string",
      "description": "Type of the target entity",
      "enum": [
        "Initiative",
        "Project",
        "Campaign",
        "Movement"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score for this relationship (0-1)"
    },
    "source_reference": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "official",
            "news",
            "research",
            "social",
            "government",
            "ngo",
            "corporate",
            "other"
          ]
        },
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "type",
        "name"
      ],
      "description": "Source of the relationship information"
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "When the relationship became valid"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "When the relationship ceased to be valid"
    },
    "is_current": {
      "type": "boolean",
      "description": "Whether the relationship is currently active"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this record was created"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this record was last updated"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes about the relationship"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tags for categorizing the relationship"
    },
    "role": {
      "type": "string",
      "description": "The specific role the actor plays in initiating (e.g., founder, co-initiator, sponsor)"
    },
    "start_date": {
      "type": "string",
      "format": "date",
      "description": "When the initiation occurred"
    },
    "motivation": {
      "type": "string",
      "description": "The stated motivation for initiating"
    },
    "context": {
      "type": "string",
      "description": "Circumstances or events that led to initiation"
    }
  },
  "x-inverse": "initiated_by",
  "x-cardinality": "one-to-many"
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://changemappers.org/schemas/relationships/derives_from.schema.json",
  "title": "Derives From",
  "description": "An Entity is sourced, originated, or derived from another Entity. This captures lineage, origins, and evolutionary relationships.",
  "type": "object",
  "required": [
    "id",
    "source_id",
    "target_id",
    "relationship_type"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the relationship"
    },
    "source_id": {
      "type": "string",
      "format": "uuid",
      "description": "ID of the source entity"
    },
    "target_id": {
      "type": "string",
      "format": "uuid",
      "description": "ID of the target entity"
    },
    "relationship_type": {
      "type": "string",
      "const": "derives_from",
      "description": "Type of relationship"
    },
    "source_type": {
      "type": "string",
      "description": "Type of the source entity",
      "enum": [
        "Initiative",
        "Pattern",
        "Methodology",
        "Organization",
        "Knowledge"
      ]
    },
    "target_type": {
      "type": "string",
      "description": "Type of the target entity",
      "enum": [
        "Initiative",
        "Pattern",
        "Methodology",
        "Organization",
        "Knowledge"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score for this relationship (0-1)"
    },
    "source_reference": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "official",
            "news",
            "research",
            "social",
            "government",
            "ngo",
            "corporate",
            "other"
          ]
        },
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "type",
        "name"
      ],
      "description": "Source of the relationship information"
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "When the relationship became valid"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "When the relationship ceased to be valid"
    },
    "is_current": {
      "type": "boolean",
      "description": "Whether the relationship is currently active"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this record was created"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this record was last updated"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes about the relationship"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tags for categorizing the relationship"
    },
    "derivation_type": {
      "type": "string",
      "description": "How it derived (adaptation, inspiration, evolution, fork)"
    },
    "modifications": {
      "type": "string",
      "description": "What was modified from the source"
    },
    "derivation_date": {
      "type": "string",
      "format": "date",
      "description": "When the derivation occurred"
    },
    "attribution": {
      "type": "string",
      "description": "How the source is credited"
    }
  },
  "x-inverse": "derived_into",
  "x-cardinality": "many-to-one"
}

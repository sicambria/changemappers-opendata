{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://changemappers.org/schemas/relationships/funds.schema.json",
  "title": "Funds",
  "description": "An Organization or Actor provides financial resources, grants, or funding to another Entity. This captures financial support relationships.",
  "type": "object",
  "required": [
    "id",
    "source_id",
    "target_id",
    "relationship_type",
    "funding_type"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the relationship"
    },
    "source_id": {
      "type": "string",
      "format": "uuid",
      "description": "ID of the source entity"
    },
    "target_id": {
      "type": "string",
      "format": "uuid",
      "description": "ID of the target entity"
    },
    "relationship_type": {
      "type": "string",
      "const": "funds",
      "description": "Type of relationship"
    },
    "source_type": {
      "type": "string",
      "description": "Type of the source entity",
      "enum": [
        "Organization",
        "Foundation",
        "Government",
        "Donor",
        "Actor"
      ]
    },
    "target_type": {
      "type": "string",
      "description": "Type of the target entity",
      "enum": [
        "Initiative",
        "Organization",
        "Project",
        "Research",
        "Campaign"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score for this relationship (0-1)"
    },
    "source_reference": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "official",
            "news",
            "research",
            "social",
            "government",
            "ngo",
            "corporate",
            "other"
          ]
        },
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "type",
        "name"
      ],
      "description": "Source of the relationship information"
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "When the relationship became valid"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "When the relationship ceased to be valid"
    },
    "is_current": {
      "type": "boolean",
      "description": "Whether the relationship is currently active"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this record was created"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this record was last updated"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes about the relationship"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tags for categorizing the relationship"
    },
    "funding_type": {
      "type": "string",
      "description": "Type of funding (grant, donation, investment, loan)"
    },
    "amount": {
      "type": "number",
      "description": "Amount of funding"
    },
    "currency": {
      "type": "string",
      "description": "Currency of funding"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Date funding was provided"
    },
    "duration": {
      "type": "string",
      "description": "Period funding covers"
    },
    "restrictions": {
      "type": "string",
      "description": "Conditions or restrictions on funding use"
    },
    "renewal_status": {
      "type": "string",
      "description": "Whether funding is one-time or recurring"
    }
  },
  "x-inverse": "funded_by",
  "x-cardinality": "many-to-many"
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://changemappers.org/schemas/relationships/requires.schema.json",
  "title": "Requires",
  "description": "An Entity depends on, needs, or cannot function without another Entity. This captures dependencies, prerequisites, and resource requirements.",
  "type": "object",
  "required": [
    "id",
    "source_id",
    "target_id",
    "relationship_type",
    "requirement_type"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the relationship"
    },
    "source_id": {
      "type": "string",
      "format": "uuid",
      "description": "ID of the source entity"
    },
    "target_id": {
      "type": "string",
      "format": "uuid",
      "description": "ID of the target entity"
    },
    "relationship_type": {
      "type": "string",
      "const": "requires",
      "description": "Type of relationship"
    },
    "source_type": {
      "type": "string",
      "description": "Type of the source entity",
      "enum": [
        "Initiative",
        "Project",
        "Organization",
        "Pattern",
        "Methodology"
      ]
    },
    "target_type": {
      "type": "string",
      "description": "Type of the target entity",
      "enum": [
        "Resource",
        "Skill",
        "Knowledge",
        "Technology",
        "Funding",
        "Permission",
        "Partnership"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score for this relationship (0-1)"
    },
    "source_reference": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "official",
            "news",
            "research",
            "social",
            "government",
            "ngo",
            "corporate",
            "other"
          ]
        },
        "name": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "type",
        "name"
      ],
      "description": "Source of the relationship information"
    },
    "valid_from": {
      "type": "string",
      "format": "date-time",
      "description": "When the relationship became valid"
    },
    "valid_to": {
      "type": "string",
      "format": "date-time",
      "description": "When the relationship ceased to be valid"
    },
    "is_current": {
      "type": "boolean",
      "description": "Whether the relationship is currently active"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this record was created"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this record was last updated"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes about the relationship"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tags for categorizing the relationship"
    },
    "requirement_type": {
      "type": "string",
      "description": "Type of requirement (essential, recommended, optional)"
    },
    "availability_status": {
      "type": "string",
      "description": "Current availability (available, scarce, unavailable)"
    },
    "quantity_needed": {
      "type": "string",
      "description": "Amount or quantity required"
    },
    "timeframe": {
      "type": "string",
      "description": "When the requirement is needed"
    },
    "consequence_if_missing": {
      "type": "string",
      "description": "What happens if requirement is not met"
    }
  },
  "x-inverse": "required_by",
  "x-cardinality": "many-to-many"
}
